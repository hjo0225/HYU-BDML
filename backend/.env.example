# Ditto Backend 환경변수 예시
# 복사 후 .env 파일로 저장하고 실제 값으로 채워주세요.
# .env 파일은 절대 git 에 커밋하지 마세요.

# DB (로컬 기본값은 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Cloud SQL 예시: postgresql+asyncpg://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Phase 5 V2 평가에서 사용)
ANTHROPIC_API_KEY=sk-ant-...

# JWT
JWT_SECRET_KEY=your-very-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (배포 환경에서 프론트엔드 URL 추가)
CORS_ORIGINS=https://your-frontend-url.run.app

# 환경
ENVIRONMENT=development

# 관리자 이메일 (콤마 구분)
ADMIN_EMAILS=your@email.com
